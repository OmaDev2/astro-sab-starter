---
import { getCollection } from 'astro:content'
import business from '../data/business.json'

const serviceEntries = await getCollection('services').catch(() => [])
const serviceLinks = serviceEntries.length > 0
  ? serviceEntries.map((s: any) => ({ name: s.data.name, href: `/servicios/${s.id}/` }))
  : (business.services as string[]).map((name) => ({
      name,
      href: `/servicios/${name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-')}/`
    }))

const year = new Date().getFullYear()
---

<footer class="bg-neutral text-neutral-content border-t border-neutral-content/10">
  <div class="max-w-6xl mx-auto px-6 py-14">
    <div class="grid md:grid-cols-3 gap-10 mb-10">

      <!-- NAP -->
      <div>
        <span class="text-xl font-bold text-neutral-content block mb-3">{business.name}</span>
        <p class="text-sm text-neutral-content/60 mb-5 leading-relaxed">{business.description}</p>
        <div class="space-y-2">
          <a href={`tel:${business.phone}`} class="flex items-center gap-2 text-sm text-neutral-content/70 hover:text-neutral-content transition-colors">
            <svg class="w-4 h-4 text-brand-accent shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
            </svg>
            {business.phone}
          </a>
          {business.email && (
            <a href={`mailto:${business.email}`} class="flex items-center gap-2 text-sm text-neutral-content/70 hover:text-neutral-content transition-colors">
              <svg class="w-4 h-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {business.email}
            </a>
          )}
          <p class="flex items-start gap-2 text-sm text-neutral-content/60">
            <svg class="w-4 h-4 text-brand-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" clip-rule="evenodd"/>
            </svg>
            {business.serviceArea.slice(0, 3).join(', ')}
            {business.serviceArea.length > 3 && ` y ${business.serviceArea.length - 3} más`}
          </p>
        </div>
      </div>

      <!-- Servicios -->
      <div>
        <span class="text-sm font-bold uppercase tracking-widest text-neutral-content/50 block mb-4">Servicios</span>
        <ul class="space-y-2">
          {serviceLinks.map(({ name, href }) => (
            <li>
              <a href={href} class="text-sm text-neutral-content/65 hover:text-neutral-content transition-colors flex items-center gap-1.5 group">
                <svg class="w-3 h-3 text-brand-accent opacity-0 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 5l7 7-7 7"/>
                </svg>
                {name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <span class="text-sm font-bold uppercase tracking-widest text-neutral-content/50 block mb-4">Legal</span>
        <ul class="space-y-2">
          <li><a href="/legal/aviso-legal/" class="text-sm text-neutral-content/65 hover:text-neutral-content transition-colors">Aviso Legal</a></li>
          <li><a href="/legal/politica-privacidad/" class="text-sm text-neutral-content/65 hover:text-neutral-content transition-colors">Política de Privacidad</a></li>
          <li><a href="/legal/politica-cookies/" class="text-sm text-neutral-content/65 hover:text-neutral-content transition-colors">Política de Cookies</a></li>
        </ul>
      </div>

    </div>

    <div class="border-t border-neutral-content/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-neutral-content/40">
      <p>© {year} {business.name} — Todos los derechos reservados</p>
      <p>Hecho con ❤️ en España</p>
    </div>
  </div>
</footer>
