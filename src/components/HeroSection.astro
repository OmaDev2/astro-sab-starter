---
import { Image } from 'astro:assets'
import business from '../data/business.json'
import home from '../data/home.json'

interface Props {
  h1: string
  subtitle?: string
  ctaText?: string
  ctaHref?: string
}

const {
  h1,
  subtitle = `Servicio profesional en ${business.serviceArea?.[0] || 'tu zona'} y alrededores`,
} = Astro.props

const phone = business.phone || ''
const whatsappNumber = phone.replace(/[\s\-\+]/g, '')
const whatsappBase = `https://wa.me/${whatsappNumber}`

// Glob import — no falla si el archivo no existe todavía (antes de ejecutar `images`)
const heroImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/home-hero.{jpg,jpeg,png,webp}',
  { eager: true }
)
const heroImageEntry = Object.values(heroImages)[0]
const heroImage = heroImageEntry?.default
const heroImageAlt = home.heroImageAlt || `${business.name} profesional en ${business.serviceArea?.[0]}`
---

<section class="relative overflow-hidden bg-neutral min-h-[90vh] flex items-center">

  <!-- Background image + multicapa gradient -->
  {heroImage && (
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImage}
        alt={heroImageAlt}
        loading="eager"
        fetchpriority="high"
        class="w-full h-full object-cover opacity-30"
      />
    </div>
  )}
  <div class="absolute inset-0 z-0 bg-gradient-to-br from-neutral via-neutral/85 to-brand-primary/20"></div>
  <!-- Decorative blobs -->
  <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand-accent/10 rounded-full blur-3xl pointer-events-none"></div>

  <!-- Split layout -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- LEFT: Texto + trust signals -->
      <div>
        <div class="inline-flex items-center gap-2 bg-brand-accent/15 border border-brand-accent/30 text-brand-accent text-sm font-semibold px-4 py-1.5 rounded-full mb-6 backdrop-blur-sm">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Presupuesto gratuito sin compromiso
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-black text-neutral-content leading-[1.05] mb-6 tracking-tight">
          {h1}
        </h1>

        <p class="text-lg md:text-xl text-neutral-content/70 mb-8 leading-relaxed max-w-lg">{subtitle}</p>

        <!-- Trust signals -->
        <ul class="space-y-3 mb-10">
          {[
            'Respuesta en menos de 1 hora',
            'Sin visita previa innecesaria',
            'Garantía de trabajo realizado',
          ].map(item => (
            <li class="flex items-center gap-3 text-neutral-content/80 text-sm">
              <div class="w-5 h-5 rounded-full bg-green-500/20 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              {item}
            </li>
          ))}
        </ul>

        <!-- Teléfono visible en móvil -->
        <a
          href={`tel:${phone}`}
          class="lg:hidden inline-flex items-center justify-center gap-3 w-full px-6 py-4 border border-neutral-content/20 bg-neutral-content/5 backdrop-blur-sm text-neutral-content hover:bg-neutral-content/10 font-bold rounded-2xl text-lg transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
          </svg>
          Llamar — {phone}
        </a>
      </div>

      <!-- RIGHT: Formulario de presupuesto -->
      <div>
        <div class="bg-base-100 rounded-3xl shadow-2xl shadow-black/30 p-8 border border-base-200">
          <h2 class="text-2xl font-bold text-base-content mb-1">Solicita tu presupuesto</h2>
          <p class="text-base-content/50 text-sm mb-6">Gratis · Sin compromiso · Respuesta en &lt;1h</p>

          <form
            id="hero-form"
            name="presupuesto-hero"
            method="POST"
            action="/gracias/"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-4"
          >
            <input type="hidden" name="form-name" value="presupuesto-hero" />
            <p class="hidden"><label>No rellenar: <input name="bot-field" /></label></p>

            <div>
              <label for="hero-nombre" class="block text-sm font-semibold text-base-content/80 mb-1.5">
                Nombre <span class="text-red-500">*</span>
              </label>
              <input
                type="text" id="hero-nombre" name="nombre" required
                autocomplete="given-name" placeholder="Tu nombre"
                class="w-full px-4 py-3 rounded-xl border border-base-300 bg-base-200/50 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none text-base-content placeholder-base-content/40 transition-all"
              />
            </div>

            <!-- Teléfono + Población en fila -->
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="hero-telefono" class="block text-sm font-semibold text-base-content/80 mb-1.5">
                  Teléfono <span class="text-red-500">*</span>
                </label>
                <input
                  type="tel" id="hero-telefono" name="telefono" required
                  autocomplete="tel" placeholder="612 345 678"
                  class="w-full px-4 py-3 rounded-xl border border-base-300 bg-base-200/50 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none text-base-content placeholder-base-content/40 transition-all"
                />
              </div>
              <div>
                <label for="hero-poblacion" class="block text-sm font-semibold text-base-content/80 mb-1.5">
                  Población
                </label>
                <input
                  type="text" id="hero-poblacion" name="poblacion"
                  autocomplete="address-level2" placeholder="Tu ciudad"
                  class="w-full px-4 py-3 rounded-xl border border-base-300 bg-base-200/50 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none text-base-content placeholder-base-content/40 transition-all"
                />
              </div>
            </div>

            <div>
              <label for="hero-email" class="block text-sm font-semibold text-base-content/80 mb-1.5">
                Email
              </label>
              <input
                type="email" id="hero-email" name="email"
                autocomplete="email" placeholder="tucorreo@ejemplo.com"
                class="w-full px-4 py-3 rounded-xl border border-base-300 bg-base-200/50 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none text-base-content placeholder-base-content/40 transition-all"
              />
            </div>

            <div>
              <label for="hero-servicio" class="block text-sm font-semibold text-base-content/80 mb-1.5">
                Servicio
              </label>
              <select
                id="hero-servicio" name="servicio"
                class="w-full px-4 py-3 rounded-xl border border-base-300 bg-base-200/50 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none text-base-content transition-all"
              >
                <option value="">Selecciona un servicio...</option>
                {business.services?.map((s: string) => (
                  <option value={s}>{s}</option>
                ))}
              </select>
            </div>

            <!-- CTA principal: WhatsApp -->
            <button
              type="button" id="btn-whatsapp"
              class="w-full flex items-center justify-center gap-3 py-4 bg-green-500 hover:bg-green-600 text-white font-bold rounded-xl text-lg transition-colors shadow-lg shadow-green-500/25"
            >
              <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Pedir presupuesto por WhatsApp
            </button>

            <div class="flex items-center gap-3 text-gray-400 text-xs">
              <div class="flex-1 h-px bg-gray-200"></div>
              <span>o enviar por email</span>
              <div class="flex-1 h-px bg-gray-200"></div>
            </div>

            <button
              type="submit"
              class="w-full py-3 bg-brand-primary hover:bg-brand-primary/90 text-white font-semibold rounded-xl transition-colors text-sm"
            >
              Enviar solicitud
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<script define:vars={{ whatsappBase }}>
  document.getElementById('btn-whatsapp')?.addEventListener('click', () => {
    const nombre = document.getElementById('hero-nombre')?.value?.trim()
    const telefono = document.getElementById('hero-telefono')?.value?.trim()
    const poblacion = document.getElementById('hero-poblacion')?.value?.trim()
    const email = document.getElementById('hero-email')?.value?.trim()
    const servicio = document.getElementById('hero-servicio')?.value

    let msg = 'Hola, me gustaría solicitar un presupuesto.'
    if (nombre) msg += `\n\n*Nombre:* ${nombre}`
    if (telefono) msg += `\n*Teléfono:* ${telefono}`
    if (email) msg += `\n*Email:* ${email}`
    if (poblacion) msg += `\n*Población:* ${poblacion}`
    if (servicio) msg += `\n*Servicio:* ${servicio}`

    window.open(`${whatsappBase}?text=${encodeURIComponent(msg)}`, '_blank', 'noopener,noreferrer')
  })
</script>
