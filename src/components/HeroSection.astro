---
import { Image } from 'astro:assets'
import business from '../data/business.json'

interface Props {
  h1: string
  subtitle?: string
  ctaText?: string
  ctaHref?: string
  heroImageUrl: string
  heroImageAlt: string
}

const {
  h1,
  subtitle = `Servicio profesional en ${business.serviceArea[0]} y alrededores`,
  ctaText = 'Solicitar presupuesto gratis',
  ctaHref = '#contacto',
  heroImageUrl,
  heroImageAlt,
} = Astro.props
---

<section class="relative overflow-hidden bg-brand-dark min-h-[70vh] flex items-center">
  <!-- Background image — LCP: eager + fetchpriority high -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImageUrl}
      alt={heroImageAlt}
      width={1920}
      height={1080}
      loading="eager"
      fetchpriority="high"
      format="avif"
      fallbackFormat="webp"
      quality={80}
      class="w-full h-full object-cover opacity-30"
      inferSize={heroImageUrl.startsWith('http')}
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-6 py-24">
    <div class="max-w-2xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {h1}
      </h1>
      <p class="text-xl text-gray-300 mb-8">{subtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 bg-brand-accent hover:bg-brand-accent/90 text-white font-semibold rounded-lg text-lg transition-colors"
        >
          {ctaText}
        </a>
        <a
          href={`tel:${business.phone}`}
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white hover:bg-white hover:text-brand-dark font-semibold rounded-lg text-lg transition-colors"
        >
          {business.phone}
        </a>
      </div>
    </div>
  </div>
</section>
