---
import business from '../data/business.json'

const phone = business.phone || ''
const whatsappNumber = phone.replace(/[\s\-\+]/g, '')
const whatsappMsg = encodeURIComponent(`Hola, me gustaría solicitar un presupuesto para ${business.services?.[0] || 'sus servicios'}.`)
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMsg}`

const navLinks = [
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Zonas', href: '/#zonas' },
  { label: 'Contacto', href: '/#contacto' },
]
---

<header id="navbar" class="sticky top-0 z-50 transition-all duration-300 bg-neutral/95 backdrop-blur-md border-b border-neutral-content/10 shadow-lg">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="text-lg font-bold text-neutral-content hover:text-brand-accent transition-colors shrink-0 tracking-tight">
      {business.name}
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-neutral-content/70">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="hover:text-neutral-content transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTAs -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href={`tel:${phone}`}
        class="flex items-center gap-2 text-neutral-content/80 font-semibold text-sm hover:text-neutral-content transition-colors"
      >
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
        </svg>
        {phone}
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2 bg-green-500 hover:bg-green-400 text-white font-semibold text-sm rounded-lg transition-all shadow-md shadow-green-500/20 hover:shadow-green-500/40 hover:-translate-y-0.5"
      >
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Presupuesto gratis
      </a>
    </div>

    <!-- Mobile -->
    <div class="flex md:hidden items-center gap-3">
      <a href={`tel:${phone}`} class="text-neutral-content font-bold text-sm">
        📞 {phone}
      </a>
      <button
        id="nav-toggle"
        class="text-neutral-content p-1"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-neutral border-t border-neutral-content/10 px-6 py-4 space-y-1" role="navigation">
    {navLinks.map(link => (
      <a href={link.href} class="block text-neutral-content/70 hover:text-neutral-content py-3 border-b border-neutral-content/10 last:border-0 text-sm font-medium">
        {link.label}
      </a>
    ))}
    <div class="pt-3 pb-1">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full py-3 bg-green-500 hover:bg-green-400 text-white font-bold rounded-xl transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Presupuesto por WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')
  const menu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    menu?.classList.toggle('hidden', isOpen)
    iconOpen?.classList.toggle('hidden', !isOpen)
    iconClose?.classList.toggle('hidden', isOpen)
    toggle.setAttribute('aria-expanded', String(!isOpen))
  })

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden')
      iconOpen?.classList.remove('hidden')
      iconClose?.classList.add('hidden')
      toggle?.setAttribute('aria-expanded', 'false')
    })
  })
</script>
