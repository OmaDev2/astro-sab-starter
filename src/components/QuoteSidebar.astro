---
/**
 * QuoteSidebar.astro — sidebar sticky de conversión
 * Usado en páginas de servicio y ciudad
 */
import business from '../data/business.json'

interface Props {
  /** Título del box principal */
  heading?: string
  /** Lista de links rápidos (ej: otros servicios o ciudades) */
  links?: { label: string; href: string }[]
  /** Etiqueta de la sección de links */
  linksHeading?: string
}

const {
  heading = 'Presupuesto gratis',
  links = [],
  linksHeading = 'Servicios relacionados',
} = Astro.props

const phone = business.phone || ''
const whatsappNumber = phone.replace(/[\s\-\+]/g, '')
const whatsappBase = `https://wa.me/${whatsappNumber}`
---

<aside class="w-full space-y-4">

  <!-- ── BOX PRINCIPAL: Formulario presupuesto ─────── -->
  <div class="bg-base-100 rounded-2xl shadow-lg border border-base-200 overflow-hidden">

    <!-- Header del box -->
    <div class="bg-brand-primary px-6 py-4">
      <h3 class="text-white font-bold text-lg flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        {heading}
      </h3>
      <p class="text-white/80 text-xs mt-0.5">Sin compromiso · Respuesta en &lt;1h</p>
    </div>

    <div class="p-5 space-y-3">
      <!-- Teléfono directo -->
      <a
        href={`tel:${phone}`}
        class="flex items-center justify-center gap-3 w-full py-3.5 bg-neutral hover:bg-neutral/80 text-neutral-content font-bold rounded-xl transition-colors text-sm"
      >
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
        </svg>
        Llamar — {phone}
      </a>

      <!-- Mini form WhatsApp -->
      <form id="sidebar-form" class="space-y-2.5">
        <input
          type="text" id="sb-nombre" name="nombre"
          placeholder="Tu nombre"
          class="w-full px-3.5 py-2.5 rounded-lg border border-base-300 bg-base-200/50 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none text-sm text-base-content placeholder-base-content/40 transition-all"
        />
        <input
          type="tel" id="sb-telefono" name="telefono"
          placeholder="Tu teléfono"
          class="w-full px-3.5 py-2.5 rounded-lg border border-base-300 bg-base-200/50 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none text-sm text-base-content placeholder-base-content/40 transition-all"
        />
        <button
          type="button" id="sb-btn-whatsapp"
          class="w-full flex items-center justify-center gap-2.5 py-3 bg-green-500 hover:bg-green-600 text-white font-bold rounded-xl transition-colors text-sm shadow-md shadow-green-500/20"
        >
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar por WhatsApp
        </button>
      </form>

      <!-- Trust signals -->
      <ul class="space-y-1.5 pt-1 border-t border-base-200">
        {[
          '✅ Presupuesto sin compromiso',
          '⚡ Respuesta en menos de 1h',
          '🏆 Garantía de trabajo',
        ].map(item => (
          <li class="text-xs text-base-content/55 flex items-center gap-1.5">{item}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- ── BOX LINKS RÁPIDOS ─────────────────────────── -->
  {links.length > 0 && (
    <div class="bg-base-100 rounded-2xl shadow-sm border border-base-200 p-5">
      <h4 class="text-sm font-bold text-base-content mb-3 uppercase tracking-wide">{linksHeading}</h4>
      <ul class="space-y-1">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              data-astro-prefetch="hover"
              class="flex items-center gap-2 text-sm text-base-content/65 hover:text-brand-primary py-1.5 border-b border-base-100 last:border-0 transition-colors group"
            >
              <span class="text-brand-primary group-hover:translate-x-0.5 transition-transform">→</span>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

</aside>

<script define:vars={{ whatsappBase }}>
  document.getElementById('sb-btn-whatsapp')?.addEventListener('click', () => {
    const nombre = document.getElementById('sb-nombre')?.value?.trim()
    const telefono = document.getElementById('sb-telefono')?.value?.trim()

    let msg = 'Hola, me gustaría solicitar un presupuesto.'
    if (nombre) msg += `\n\n*Nombre:* ${nombre}`
    if (telefono) msg += `\n*Teléfono:* ${telefono}`

    window.open(`${whatsappBase}?text=${encodeURIComponent(msg)}`, '_blank', 'noopener,noreferrer')
  })
</script>
