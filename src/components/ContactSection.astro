---
import business from '../data/business.json'
---

<section id="contacto" class="py-20 bg-neutral text-neutral-content relative overflow-hidden">
  <!-- Decorative gradient blob -->
  <div class="absolute -top-32 -right-32 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- Left: info -->
      <div class="reveal">
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-brand-accent mb-4">Contacto</span>
        <h2 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">Solicita tu presupuesto <span class="text-brand-accent">gratis</span></h2>
        <p class="text-neutral-content/65 mb-8 text-lg">Sin compromiso. Respuesta en menos de 24 horas.</p>

        <div class="space-y-4">
          <a href={`tel:${business.phone}`} class="flex items-center gap-4 group">
            <div class="w-11 h-11 rounded-xl bg-brand-primary/20 flex items-center justify-center shrink-0 group-hover:bg-brand-primary/40 transition-colors">
              <svg class="w-5 h-5 text-brand-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
              </svg>
            </div>
            <span class="text-lg font-semibold group-hover:text-brand-accent transition-colors">{business.phone}</span>
          </a>
          {business.email && (
            <a href={`mailto:${business.email}`} class="flex items-center gap-4 group">
              <div class="w-11 h-11 rounded-xl bg-brand-primary/20 flex items-center justify-center shrink-0 group-hover:bg-brand-primary/40 transition-colors">
                <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <span class="text-lg font-semibold group-hover:text-brand-accent transition-colors">{business.email}</span>
            </a>
          )}
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal reveal-delay-2">
        <form
          name="contacto"
          method="POST"
          action="/gracias/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 space-y-4"
        >
          <input type="hidden" name="form-name" value="contacto" />
          <p class="hidden"><label>No rellenar: <input name="bot-field" /></label></p>

          <div>
            <label for="nombre" class="block text-sm font-medium mb-1.5 text-neutral-content/80">Nombre</label>
            <input type="text" id="nombre" name="nombre" required
              class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/15 text-neutral-content placeholder-neutral-content/40 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition-all"
              placeholder="Tu nombre" />
          </div>
          <div>
            <label for="telefono" class="block text-sm font-medium mb-1.5 text-neutral-content/80">Teléfono</label>
            <input type="tel" id="telefono" name="telefono" required
              class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/15 text-neutral-content placeholder-neutral-content/40 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition-all"
              placeholder="612 345 678" />
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-medium mb-1.5 text-neutral-content/80">¿En qué puedo ayudarte?</label>
            <textarea id="mensaje" name="mensaje" rows="3"
              class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/15 text-neutral-content placeholder-neutral-content/40 focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition-all resize-none"
              placeholder="Describe tu proyecto o servicio que necesitas..."></textarea>
          </div>
          <button type="submit"
            class="w-full py-4 bg-brand-accent hover:bg-brand-accent/90 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-accent/25 hover:shadow-brand-accent/40 hover:-translate-y-0.5">
            Enviar solicitud
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
