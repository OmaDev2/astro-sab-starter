---
import business from '../data/business.json'
---

<section id="contacto" class="py-20 bg-brand-dark text-white">
  <div class="max-w-4xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-4">Solicita tu presupuesto</h2>
        <p class="text-gray-300 mb-8">Sin compromiso. Respuesta en menos de 24 horas.</p>
        <div class="space-y-4">
          <p class="flex items-center gap-3 text-lg">
            <span>📞</span>
            <a href={`tel:${business.phone}`} class="hover:text-brand-accent">{business.phone}</a>
          </p>
          {business.email && (
            <p class="flex items-center gap-3 text-lg">
              <span>✉️</span>
              <a href={`mailto:${business.email}`} class="hover:text-brand-accent">{business.email}</a>
            </p>
          )}
        </div>
      </div>
      <!-- Netlify Forms — cero JS, redirige a /gracias/ para tracking conversiones -->
      <form
        name="contacto"
        method="POST"
        action="/gracias/"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="bg-white/10 backdrop-blur rounded-2xl p-8 space-y-4"
      >
        <input type="hidden" name="form-name" value="contacto" />
        <p class="hidden">
          <label>No rellenar: <input name="bot-field" /></label>
        </p>
        <div>
          <label for="nombre" class="block text-sm font-medium mb-1">Nombre</label>
          <input type="text" id="nombre" name="nombre" required
            class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-brand-accent"
            placeholder="Tu nombre" />
        </div>
        <div>
          <label for="telefono" class="block text-sm font-medium mb-1">Teléfono</label>
          <input type="tel" id="telefono" name="telefono" required
            class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-brand-accent"
            placeholder="612 345 678" />
        </div>
        <div>
          <label for="mensaje" class="block text-sm font-medium mb-1">¿En qué puedo ayudarte?</label>
          <textarea id="mensaje" name="mensaje" rows="3"
            class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-brand-accent resize-none"
            placeholder="Describe tu problema o servicio que necesitas..."></textarea>
        </div>
        <button type="submit"
          class="w-full py-4 bg-brand-accent hover:bg-brand-accent/90 text-white font-bold rounded-lg transition-colors">
          Enviar solicitud
        </button>
      </form>
    </div>
  </div>
</section>
