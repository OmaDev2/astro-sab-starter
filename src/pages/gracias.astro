---
import BaseLayout from '../layouts/BaseLayout.astro'
import business from '../data/business.json'
---

<BaseLayout
  title={`Solicitud recibida | ${business.name}`}
  description="Hemos recibido tu solicitud de presupuesto. Te contactaremos en menos de 24 horas."
  noSchema={true}
  noindex={true}
>
  <section class="min-h-screen flex items-center justify-center bg-base-200 px-6">
    <div class="max-w-lg text-center">
      <!-- Icono de confirmación -->
      <div class="w-20 h-20 bg-green-500/15 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-base-content mb-4">
        ¡Solicitud recibida!
      </h1>
      <p class="text-lg text-base-content/70 mb-2">
        Gracias por contactar con <strong>{business.name}</strong>.
      </p>
      <p class="text-base-content/55 mb-8">
        Te responderemos en menos de <strong>24 horas</strong>.
        Si tienes urgencia, llámanos directamente:
      </p>

      <a
        href={`tel:${business.phone}`}
        class="inline-flex items-center justify-center px-8 py-4 bg-brand-accent hover:bg-brand-accent/90 text-white font-bold rounded-lg text-lg transition-colors mb-4 w-full sm:w-auto"
      >
        📞 Llamar ahora — {business.phone}
      </a>

      <br />

      <a href="/" class="text-brand-primary hover:underline text-sm mt-4 inline-block">
        ← Volver al inicio
      </a>
    </div>
  </section>
</BaseLayout>
