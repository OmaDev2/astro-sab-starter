---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroSection from '../components/HeroSection.astro'
import ServiceCard from '../components/ServiceCard.astro'
import CityGrid from '../components/CityGrid.astro'
import ContactSection from '../components/ContactSection.astro'
import { getCollection } from 'astro:content'
import business from '../data/business.json'
import home from '../data/home.json'

const services = await getCollection('services')

const heroImageUrl = home.heroImageUrl && !home.heroImageUrl.startsWith('__') ? home.heroImageUrl : ''
const heroImageAlt = home.heroImageAlt || `${business.type} profesional en ${business.serviceArea[0]}`
const h1 = home.h1 || `${business.name} — ${business.type} en ${business.serviceArea[0]}`
const heroSubtitle = home.heroSubtitle || undefined
const ctaText = home.ctaText || 'Solicitar presupuesto gratis'
const servicesHeading = home.servicesHeading || 'Nuestros servicios'
---

<BaseLayout
  title={`${business.type} en ${business.serviceArea[0]} | ${business.name}`}
  description={`${business.description} Llámanos: ${business.phone}`}
>
  <HeroSection
    h1={h1}
    subtitle={heroSubtitle}
    ctaText={ctaText}
    heroImageUrl={heroImageUrl}
    heroImageAlt={heroImageAlt}
  />

  <!-- Servicios -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">{servicesHeading}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(service => (
          <ServiceCard
            name={service.data.name}
            description={service.data.description}
            slug={service.id}
          />
        ))}
      </div>
    </div>
  </section>

  <CityGrid />
  <ContactSection />
</BaseLayout>
