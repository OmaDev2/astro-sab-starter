---
// src/pages/servicios/[service].astro
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro'
import QuoteSidebar from '../../components/QuoteSidebar.astro'
import business from '../../data/business.json'

export async function getStaticPaths() {
  const services = await getCollection('services')
  return services.map(entry => ({
    params: { service: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { name, title, description, heroImage, price } = entry.data
const { Content } = await render(entry)

// Carga imágenes AI locales via glob — devuelve ImageMetadata para <Image> de Astro
// Astro NO puede optimizar paths dinámicos desde frontmatter; import.meta.glob = build-time
const localImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/images/*.jpg', { eager: true })
const slug = entry.id
const heroImgMeta    = localImages[`../../assets/images/${slug}-hero.jpg`]?.default
const midImgMeta     = localImages[`../../assets/images/${slug}-mid.jpg`]?.default
const closingImgMeta = localImages[`../../assets/images/${slug}-closing.jpg`]?.default

// Otros servicios para el sidebar
const allServices = await getCollection('services')
const otherServices = allServices
  .filter(s => s.id !== entry.id)
  .map(s => ({ label: s.data.name, href: `/servicios/${s.id}/` }))

const canonicalURL = new URL(`/servicios/${entry.id}/`, Astro.site).href
const breadcrumbs = [
  { name: 'Inicio', url: Astro.site!.toString() },
  { name: 'Servicios', url: new URL('/servicios/', Astro.site).href },
  { name: name, url: canonicalURL },
]
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL}>
  <BreadcrumbSchema items={breadcrumbs} />

  <!-- Hero imagen (16:9) — LCP prioritario -->
  {heroImgMeta ? (
    <div class="w-full h-64 md:h-96 overflow-hidden">
      <Image
        src={heroImgMeta}
        alt={`${name} - instalación profesional`}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  ) : heroImage && (
    <div class="w-full h-64 md:h-80 overflow-hidden">
      <Image
        src={`${heroImage}${String(heroImage).includes('?') ? '&' : '?'}w=1200&h=400&fit=crop`}
        alt={`${name} - ${business.name}`}
        width={1200}
        height={400}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="w-full h-full object-cover"
      />
    </div>
  )}

  <!-- Breadcrumbs visibles -->
  <div class="bg-base-200 border-b border-base-300">
    <div class="max-w-6xl mx-auto px-6 py-3">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-base-content/50">
        <a href="/" class="hover:text-brand-primary transition-colors">{business.name}</a>
        <span>/</span>
        <span class="text-base-content/40">Servicios</span>
        <span>/</span>
        <span class="text-base-content font-medium">{name}</span>
      </nav>
    </div>
  </div>

  <!-- Cabecera del servicio -->
  <div class="bg-base-100 border-b border-base-200">
    <div class="max-w-6xl mx-auto px-6 py-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-base-content mb-2">{name}</h1>
          <p class="text-base-content/60 text-lg">{description}</p>
        </div>
        {price && !price.startsWith('__') && (
          <div class="bg-brand-primary/10 border border-brand-primary/20 rounded-xl px-5 py-3 text-center shrink-0">
            <p class="text-xs text-brand-primary font-semibold uppercase tracking-wide mb-0.5">Precio desde</p>
            <p class="text-2xl font-black text-brand-primary">{price}</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Layout 2 columnas: contenido + sidebar -->
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="grid lg:grid-cols-[1fr_320px] gap-10 items-start">

      <!-- Columna izquierda: Contenido principal -->
      <main>
        <!-- Imagen mid (4:3) — detalle técnico, float right en desktop -->
        {midImgMeta && (
          <div class="mb-6 md:float-right md:ml-8 md:mb-4 md:w-80 lg:w-96 rounded-2xl overflow-hidden shadow-md">
            <Image
              src={midImgMeta}
              alt={`${name} - detalle del proceso`}
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
          </div>
        )}

        <article class="prose prose-lg prose-headings:text-base-content prose-headings:font-bold prose-p:text-base-content/70 prose-li:text-base-content/70 prose-strong:text-base-content prose-a:text-brand-primary max-w-none">
          <Content />
        </article>

        <!-- Imagen closing (4:3) — resultado final -->
        {closingImgMeta && (
          <div class="clear-both mt-10 rounded-2xl overflow-hidden shadow-md">
            <Image
              src={closingImgMeta}
              alt={`${name} - resultado final`}
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
          </div>
        )}

        <!-- CTA móvil (visible solo en mobile, el sidebar está arriba) -->
        <div class="mt-10 p-6 bg-brand-primary/5 border border-brand-primary/20 rounded-2xl lg:hidden">
          <h3 class="text-lg font-bold text-base-content mb-4">¿Te interesa este servicio?</h3>
          <a
            href={`https://wa.me/${business.phone?.replace(/[\s\-\+]/g, '')}?text=${encodeURIComponent(`Hola, me interesa el servicio de ${name}.`)}`}
            target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-3.5 bg-green-500 hover:bg-green-600 text-white font-bold rounded-xl transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Pedir presupuesto por WhatsApp
          </a>
        </div>
      </main>

      <!-- Columna derecha: Sidebar sticky -->
      <div class="hidden lg:block">
        <div class="sticky top-24">
          <QuoteSidebar
            heading="Presupuesto gratis"
            links={otherServices}
            linksHeading="Otros servicios"
          />
        </div>
      </div>

    </div>
  </div>

  <!-- Ciudades donde ofrecemos este servicio -->
  {business.serviceArea && business.serviceArea.length > 0 && (
    <section class="bg-base-200 border-t border-base-200 py-12">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-xl font-bold text-base-content mb-6">
          {name} en toda el área de {business.serviceArea[0]}
        </h2>
        <div class="flex flex-wrap gap-2">
          {business.serviceArea.map((city: string) => (
            <a
              href={`/${city.toLowerCase().replace(/\s+/g, '-')}/`}
              data-astro-prefetch="hover"
              class="px-4 py-2 bg-base-100 border border-base-300 hover:border-brand-primary hover:text-brand-primary rounded-lg text-sm font-medium text-base-content/65 transition-colors shadow-sm"
            >
              {name} en {city}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
