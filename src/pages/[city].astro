---
// src/pages/[city].astro — página dinámica SAB con enlazado interno
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro'
import QuoteSidebar from '../components/QuoteSidebar.astro'
import business from '../data/business.json'

export async function getStaticPaths() {
  const locations = await getCollection('locations')
  return locations.map(entry => ({
    params: { city: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { city, h1, title, description, heroImage, faqs } = entry.data
const { Content } = await render(entry)

// Servicios para el sidebar y enlazado interno
const allServices = await getCollection('services')
const serviceLinks = allServices.map(s => ({
  label: `${s.data.name} en ${city}`,
  href: `/servicios/${s.id}/`,
}))

const canonicalURL = new URL(`/${entry.id}/`, Astro.site).href
const breadcrumbs = [
  { name: 'Inicio', url: Astro.site!.toString() },
  { name: city, url: canonicalURL },
]

// FAQPage schema eliminado: Google restringe FAQPage rich results a sitios gov/health desde Aug 2023.
// Las FAQs siguen en HTML (accordion semántico) — visibles para crawlers y AI sin riesgo de penalización.
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  city={city}
>
  <BreadcrumbSchema items={breadcrumbs} />

  <!-- Hero compacto ciudad (sin formulario — el sidebar ya tiene el form) -->
  <div class="relative bg-neutral overflow-hidden">
    {heroImage && !heroImage.startsWith('__') && (
      <div class="absolute inset-0">
        <Image
          src={heroImage}
          alt={h1}
          width={1200}
          height={400}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover opacity-25"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-neutral via-neutral/80 to-neutral/50"></div>
      </div>
    )}
    <div class="relative max-w-6xl mx-auto px-6 py-14">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-content/50 mb-5">
        <a href="/" class="hover:text-neutral-content transition-colors">{business.name}</a>
        <span>/</span>
        <span class="text-neutral-content font-medium">{city}</span>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-content mb-4 max-w-3xl">
        {h1}
      </h1>
      <p class="text-neutral-content/70 text-lg max-w-2xl">{description}</p>
    </div>
  </div>

  <!-- Layout 2 columnas: contenido + sidebar -->
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="grid lg:grid-cols-[1fr_320px] gap-10 items-start">

      <!-- Columna izquierda: Contenido + FAQs -->
      <main>
        <!-- Contenido del markdown -->
        <article class="prose prose-lg prose-headings:text-base-content prose-headings:font-bold prose-p:text-base-content/70 prose-li:text-base-content/70 prose-strong:text-base-content prose-a:text-brand-primary max-w-none mb-10">
          <Content />
        </article>

        <!-- FAQs — accordion semántico -->
        {faqs && faqs.length > 0 && (
          <section class="mb-10">
            <h2 class="text-2xl font-bold text-base-content mb-6">
              Preguntas frecuentes en {city}
            </h2>
            <div class="space-y-3">
              {faqs.map((faq: { question: string; answer: string }) => (
                <details class="group bg-base-100 border border-base-200 rounded-xl overflow-hidden shadow-sm">
                  <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none font-semibold text-base-content hover:bg-base-200 transition-colors gap-4">
                    <span>{faq.question}</span>
                    <svg
                      class="w-5 h-5 text-brand-primary shrink-0 transition-transform duration-200 group-open:rotate-180"
                      fill="none" viewBox="0 0 24 24" stroke="currentColor"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </summary>
                  <div class="px-6 pb-5 text-base-content/70 leading-relaxed border-t border-base-200 pt-4">
                    {faq.answer}
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- CTA móvil -->
        <div class="p-6 bg-brand-primary/5 border border-brand-primary/20 rounded-2xl lg:hidden">
          <h3 class="text-lg font-bold text-base-content mb-4">¿Necesitas {business.name} en {city}?</h3>
          <a
            href={`https://wa.me/${business.phone?.replace(/[\s\-\+]/g, '')}?text=${encodeURIComponent(`Hola, me gustaría solicitar un presupuesto en ${city}.`)}`}
            target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-3.5 bg-green-500 hover:bg-green-600 text-white font-bold rounded-xl transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Solicitar presupuesto en {city}
          </a>
        </div>
      </main>

      <!-- Columna derecha: Sidebar sticky -->
      <div class="hidden lg:block">
        <div class="sticky top-24">
          <QuoteSidebar
            heading={`Presupuesto en ${city}`}
            links={serviceLinks}
            linksHeading="Servicios disponibles"
          />
        </div>
      </div>

    </div>
  </div>

</BaseLayout>
